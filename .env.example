MYSQL_DATABASE=harborops
MYSQL_USER=harborops
MYSQL_PASSWORD=replace-with-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=replace-with-strong-root-password

APP_RUNTIME_PROFILE=dev
REQUEST_SIGNING_PREFIXES=/api/jobs/
DJANGO_HTTPS_ENABLED=true

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-strong-django-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=https://localhost:8443
CSRF_TRUSTED_ORIGINS=https://localhost:8443

VITE_API_BASE_URL=https://localhost:8443

# 32-byte key, base64 encoded (required)
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
APP_AES256_KEY_B64=

BACKUP_PASSPHRASE=replace-with-strong-passphrase
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_HOUR=2
BACKUP_SCHEDULE_MINUTE=0

OFFLINE_INGEST_FOLDERS=/app/offline_dropzone
OFFLINE_INGEST_INTERVAL_SECONDS=30
